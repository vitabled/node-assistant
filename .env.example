# Secret key: encrypts the infra-billing vault AND signs account session JWTs.
# MUST be changed — the default lets anyone forge a token for any account.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=change_me_32_hex_chars_minimum_here

# Max concurrent SSH sessions
MAX_SSH_SESSIONS=5

# Task log buffer size (lines kept in memory per task)
LOG_BUFFER_SIZE=2000

# CORS origin for frontend (change in production)
CORS_ORIGIN=http://localhost

# ── Optional service split (Plan M) ───────────────────────────────
# Where deploy tasks and their live logs are kept.
#   memory  (default) — in-process; single-container deployment.
#   shared            — SQLite under DATA_DIR; REQUIRED to hand deploys to the
#                       `deploy-worker` container, and harmless without it.
# Enable the workers with: docker compose --profile split up -d
# TASK_STORE=shared

# Shared secret guarding /internal/agg-subs and the aggregator's /refresh.
# Empty disables the guard (dev only) — set a strong value in production.
# AGG_TOKEN=
