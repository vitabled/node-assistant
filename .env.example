# Secret key: encrypts the infra-billing vault AND signs account session JWTs.
# MUST be changed — the default lets anyone forge a token for any account.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=change_me_32_hex_chars_minimum_here

# Max concurrent SSH sessions
MAX_SSH_SESSIONS=5

# Task log buffer size (lines kept in memory per task)
LOG_BUFFER_SIZE=2000

# CORS origin for frontend (change in production)
CORS_ORIGIN=http://localhost
