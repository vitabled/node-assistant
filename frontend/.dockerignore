# The image runs its own `npm install` (Dockerfile), so the host's
# node_modules must never enter the build context: it is platform-wrong
# (Windows-installed vs alpine) and its .bin symlinks (e.g. topo2geo) make
# BuildKit fail with "invalid file request".
node_modules

# Regenerated by `npm run build` inside the image.
dist

# Playwright screenshot artifacts (also git-ignored).
tests/e2e/shots
