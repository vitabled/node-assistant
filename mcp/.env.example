REMNAWAVE_BASE_URL=https://vpn.example.com
REMNAWAVE_API_TOKEN=your-api-token-here

# Optional: API key for Caddy reverse proxy with custom path
# See: https://docs.remnawave.com/docs/security/caddy-with-custom-path/
# REMNAWAVE_API_KEY=your-caddy-api-key

# Optional: enable readonly mode (only read/list operations, no create/update/delete)
# REMNAWAVE_READONLY=true

# Optional: node-installer panel tools (read-only). JWT Bearer = our require_account.
# NODE_ASSISTANT_BASE_URL=http://backend:8000
# NODE_ASSISTANT_TOKEN=your-node-assistant-jwt

# Optional: HTTP/SSE transport (in addition to stdio) for external MCP clients.
# When both are set, the server serves Streamable HTTP at :$MCP_HTTP_PORT/mcp,
# gated by a Bearer token; otherwise it uses stdio.
# MCP_HTTP_PORT=3100
# MCP_AUTH_TOKEN=generate-a-strong-token
